# Local: docker compose (repo root).
DATABASE_URL="postgresql://airship:airship@localhost:5433/airship?schema=public"
PORT=3000

# --- Railway (airship-app API service variables) ---
# On the API service only (not your laptop .env for runtime):
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   or postgresql://postgres:PASSWORD@postgres.railway.internal:5432/railway
# From your Mac (Prisma Studio, db:deploy, imports) use the PUBLIC proxy URL + sslmode:
#   DATABASE_URL="postgresql://postgres:PASSWORD@HOST.proxy.rlwy.net:PORT/railway?sslmode=require"
# PORT=8080
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123
# MEDIA_PUBLIC_BASE_URL=https://airship-app-production.up.railway.app
# CORS_ORIGIN=http://localhost:4200,http://localhost:4201,http://127.0.0.1:4200,http://127.0.0.1:4201,https://YOUR-ADMIN.vercel.app,https://YOUR-PUBLIC-SITE.vercel.app
# Comma-separated list; in production set explicit SPA origins (never rely on `*`).
# Include http://localhost:4201 when using the Angular admin SPA locally.
CORS_ORIGIN=http://localhost:4200,http://localhost:4201,http://127.0.0.1:4200,http://127.0.0.1:4201

# Admin SPA: HTTP Basic on /api/admin/*. Defaults in code are admin / admin123 if you omit these.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Legacy password env (still supported if ADMIN_PASSWORD is unset):
# ADMIN_API_KEY=your-long-random-secret

# Self-hosted uploads (disk). On Railway, mount a Volume at MEDIA_ROOT (e.g. /data/media).
MEDIA_ROOT=./uploads
# Public base URL for stored image links (no trailing slash). Must match your API origin.
MEDIA_PUBLIC_BASE_URL=http://localhost:3000
# Production: https://airship-app-production.up.railway.app (no trailing slash; public HTTPS — do not use :8080 in browser URLs)

# Optional: log HTTP handlers slower than N ms (default 3000). Check Railway logs for "[slow http]".
# LOG_SLOW_REQUEST_MS=3000
# Optional: log every SQL query (verbose; use briefly when debugging slow admin).
# LOG_PRISMA_QUERIES=1
